# Nodemailer Configuration
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_SERVICE=gmail
EMAIL_FROM=no-reply@codevibe.app
# Optional custom SMTP settings (use only if you want explicit SMTP instead of built-in Gmail service)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=465
# EMAIL_SECURE=true
DB_URL=mongodb+srv://<username>:<password>@cluster...

# CORS Configuration - comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://codevibeforyou.netlify.app

# Server Port
PORT=5002

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
CLIENT_URL=https://codevibeforyou.netlify.app

# GitHub Actions contributor leaderboard sync
LEADERBOARD_API_TOKEN=
